# Django Secret Key
# Generate a new one for production!
SECRET_KEY='your-django-secret-key-here'

# SECURITY WARNING: don't run with debug turned on in production!
DEBUG=True

# Google OAuth Credentials
# Obtain these from Google Cloud Console
GOOGLE_OAUTH_CLIENT_ID='your-google-client-id.apps.googleusercontent.com'
GOOGLE_OAUTH_SECRET='your-google-client-secret'

# Yandex Maps API Key
# Obtain this from Yandex Developer Console
YANDEX_MAPS_API_KEY='your-yandex-maps-api-key'
